{
  "name": "sterling-cms-api",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker — CMS API for Sterling Tax Expert",
  "scripts": {
    "dev":     "wrangler dev",
    "deploy":  "wrangler deploy",
    "tail":    "wrangler tail",
    "db:migrate":       "wrangler d1 execute sterling-cms --local --file=migrations/0001_initial.sql",
    "db:migrate:prod":  "wrangler d1 execute sterling-cms --file=migrations/0001_initial.sql",
    "db:query":         "wrangler d1 execute sterling-cms --command",
    "db:query:local":   "wrangler d1 execute sterling-cms --local --command",
    "health":  "curl -s http://localhost:8787/health | jq"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
